{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "description": "Use this preset to configure the project.",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "warnings",
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Wconversion -Wsign-conversion -Wshadow -Wnon-virtual-dtor -Wold-style-cast -Wcast-align -Wunused -Woverloaded-virtual -Werror"
            }
        },
        {
            "name": "default",
            "inherits": "base",
            "description": "Default configuration preset."
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "configuration": "Debug",
            "description": "Default build preset."
        },
        {
            "name": "release",
            "configurePreset": "default",
            "configuration": "Release",
            "description": "Release build preset."
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "description": "Default test preset."
        }
    ]
}
